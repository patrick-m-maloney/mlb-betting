# Copy this file to .env and fill in your values.
# Never commit .env — it is gitignored.
# On Railway, set these as environment variables in the Railway dashboard.

# The Odds API — https://the-odds-api.com
THE_ODDS_API_KEY=

# TheRundown API — https://rapidapi.com/therundown/api/therundown
# (dormant — no key required yet)
THERUNDOWN_API_KEY=
THE_RUNDOWN_API_KEY=

# Kalshi — no auth required for public market reads (trading needs key)
# KALSHI_API_KEY=

# Polymarket — no auth required for public market reads
# POLYMARKET_API_KEY=
